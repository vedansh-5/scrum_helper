{
  "manifest_version": 3,
  "name": "SCRUM Helper",
  "version": "2.0.0",
  "description": "Simplify writing scrums in Google Groups for FOSSASIA projects by auto-fetching GitHub activity",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://groups.google.com/*",
    "https://mail.google.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://groups.google.com/*",
        "https://mail.google.com/*",
        "https://mail.yahoo.com/*",
        "https://outlook.live.com/*",
        "https://*.outlook.com/*"
      ],
      "js": [
        "scripts/emailClientAdapter.js",
        "scripts/scrumHelper.js"
      ],
      "css": ["index.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SCRUM Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}